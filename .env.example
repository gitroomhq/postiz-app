# D3 Creator — environment configuration
# Copy to .env (or .env.local for frontend) and fill in real values.

# === Supabase ===
# Public — safe to expose to browser
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key_here"
# Private — server only, never expose to browser
# Get from: https://supabase.com/dashboard/project/<your-project-ref>/settings/api
SUPABASE_SERVICE_ROLE_KEY=""

# === Admin bootstrap ===
# Admins are determined by the public.admin_email table (NOT a Next.js env var).
# Add an admin with:
#   insert into public.admin_email (email, note) values ('you@d3.com', 'project owner');
# Any future signup with that email is auto-promoted to role='admin' by the trigger.
# To promote an EXISTING user manually:
#   update public.user_role set role = 'admin'
#     where user_id = (select id from auth.users where email = 'you@d3.com');

# === Apify ===
# Deprecated as of 2026-05-28 — kept only for legacy migrations / rollback.
# All adapters now use TikHub (IG/TikTok/Douyin/RedNote) or Bright Data (FB).
# Get from: https://console.apify.com/settings/integrations
APIFY_API_KEY=""

# === Bright Data (Web Scraper API for Facebook) ===
# Used by libraries/scrapers/facebook adapter against https://api.brightdata.com/datasets/v3
# Datasets: gd_mf124a0511bauquyow (Pages and Profiles) + gd_lkaxegm826bjpoo9m5 (Pages Posts)
# Get from: https://brightdata.com/cp/setting/users
BRIGHTDATA_API_KEY=""
# Optional override (default: https://api.brightdata.com/datasets/v3)
# BRIGHTDATA_API_BASE=""

# === Vercel Cron (production only) ===
# Random secret used to authenticate Vercel Cron requests
# Generate with: openssl rand -base64 32
CRON_SECRET=generate_with_openssl_rand_-base64_32

# === TikHub (REST API for TikTok / Instagram / Douyin / Xiaohongshu) ===
# Used by:
#   - libraries/scrapers (production REST calls to https://api.tikhub.io)
#   - .mcp.json (dev-time MCP servers at https://mcp.tikhub.io/*)
# Get from: https://tikhub.io
TIKHUB_API_KEY=""
# Optional override for mainland-CN routing (default: https://api.tikhub.io)
# TIKHUB_API_BASE="https://api.tikhub.dev"

# === Upstash (rate limiter for /api/proxy-image) ===
# Required in production for proxy-image rate limit.
# Without these the proxy-image route has no per-IP rate limiting — abuse risk.
# Optional in local dev (whitelist + content-type guard still apply when unset).
# When set, the route enforces a sliding window of 30 req per IP per 10s.
#
# Production: install the Upstash Redis integration from the Vercel
# Marketplace — it auto-injects both vars below into the project.
#   https://vercel.com/marketplace/upstash
# Local dev: copy them from the Upstash dashboard if you want to exercise
# the limiter locally; otherwise leave blank.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
