# Chrome Extension Settings (for cookie-based platform integrations like Skool)
EXTENSION_ID=""

# === AI Settings
#
# A configuracao principal de IA agora e per-workspace via UI:
# Settings > AI Provider permite cadastrar chave (OpenRouter ou OpenAI),
# escolher modelo e opcoes para cada tipo (Texto, Imagem, Video, Web Search).
# As chaves sao armazenadas criptografadas (AES-256-GCM com ENCRYPTION_KEY)
# no banco. Ver docs/architecture/ai-provider-system.md.
#
# As env vars abaixo sao opcionais — usadas apenas em features dormentes
# (HeyGen, ImageSlides) ou como fallback de catalogo. Nao sao mais
# pre-requisito para o agente, gerador de posts ou geracao de imagem.

## OpenAI (opcional — usado pelo HeyGen para TTS e pelo ImageSlides
##         para quebrar tema em slides; nao usado pelo agente nem pela
##         geracao de imagem do composer, esses respeitam Settings > AI Provider)
#OPENAI_API_KEY=""

## FAL (geracao de imagens alternativa via Ideogram v2 — usado pelo ImageSlides)
#FAL_KEY=""

## KIE.AI (geracao de video Veo3 com audio — provider dedicado, nao via Settings)
#KIEAI_API_KEY=""

## ElevenLabs (text-to-speech para narracao de slides)
#ELEVENSLABS_API_KEY=""

## Transloadit (montagem de video a partir de slides)
#TRANSLOADIT_AUTH=""
#TRANSLOADIT_SECRET=""
#TRANSLOADIT_TEMPLATE=""

## Tavily (web search — pode ser configurado em Settings > AI Provider > Web Search,
##         esta env serve apenas como fallback de teste em dev)
#TAVILY_API_KEY=""

## MCP Server (URL publica do servidor MCP — expoe o agente para clientes externos)
#MCP_URL=""

## Agent API (chaves de acesso para agente e media SSO)
#AGENT_API_KEY=""
#AGENT_MEDIA_SSO_KEY=""

# === Misc Settings
NEXT_PUBLIC_DISCORD_SUPPORT=""
NEXT_PUBLIC_POLOTNO=""
# NOT_SECURED=false
API_LIMIT=30 # The limit of the public API hour limit

