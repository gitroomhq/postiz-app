# === Apify ===
# Deprecated as of 2026-05-28 — kept only for legacy migrations / rollback.
# All adapters now use TikHub (IG/TikTok/Douyin/RedNote) or Bright Data (FB).
# Get from: https://console.apify.com/settings/integrations
APIFY_API_KEY=""

# === Bright Data (Web Scraper API for Facebook) ===
# Used by libraries/scrapers/facebook adapter against https://api.brightdata.com/datasets/v3
# Datasets: gd_mf124a0511bauquyow (Pages and Profiles) + gd_lkaxegm826bjpoo9m5 (Pages Posts)
# Get from: https://brightdata.com/cp/setting/users
BRIGHTDATA_API_KEY=""
# Optional override (default: https://api.brightdata.com/datasets/v3)
# BRIGHTDATA_API_BASE=""

# === Vercel Cron (production only) ===
# Random secret used to authenticate Vercel Cron requests
CRON_SECRET=""

# === TikHub (REST API for TikTok / Instagram / Douyin / Xiaohongshu) ===
# Used by:
#   - libraries/scrapers (production REST calls to https://api.tikhub.io)
#   - .mcp.json (dev-time MCP servers at https://mcp.tikhub.io/*)
# Get from: https://tikhub.io
TIKHUB_API_KEY=""
# Optional override for mainland-CN routing (default: https://api.tikhub.io)
# TIKHUB_API_BASE="https://api.tikhub.dev"
