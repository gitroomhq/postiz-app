# =============================================================================
# POSTIZ DESKTOP MODE CONFIGURATION
# =============================================================================
# Copy this file to .env and modify as needed for local desktop use.
# This configuration runs Postiz without Docker using PGlite and MockRedis.

# Mode flag - enables desktop-specific behavior
POSTIZ_MODE=desktop

# =============================================================================
# DATABASE (PGlite for desktop - embedded PostgreSQL)
# =============================================================================
# PGlite provides embedded PostgreSQL with full compatibility.
# Uses the SAME schema as server deployment - no separate schema needed.
# Data is stored in app data directory:
#   macOS: ~/Library/Application Support/Postiz/pglite-data/
#   Linux: ~/.local/share/postiz/pglite-data/
#   Windows: %APPDATA%/Postiz/pglite-data/
#
# For desktop mode, the app auto-configures PGlite.
# To use external PostgreSQL instead (e.g., for team use), set:
# DATABASE_URL="postgresql://user:pass@localhost:5432/postiz"
#
# Data Portability:
# - Export: Use app's export feature or copy pglite-data directory
# - Import: Initialize with existing pglite-data directory
# - Cloud migration: Export via app API, import to external PostgreSQL

# =============================================================================
# REDIS (Optional - uses MockRedis when not set)
# =============================================================================
# Redis is OPTIONAL for desktop mode. When REDIS_URL is not set,
# Postiz automatically uses in-memory MockRedis which is suitable
# for single-user desktop use.
#
# Uncomment to use a real Redis instance:
# REDIS_URL=redis://localhost:6379

# =============================================================================
# TEMPORAL (Dev server auto-started)
# =============================================================================
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="default"

# =============================================================================
# URLS (Local development)
# =============================================================================
MAIN_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:4200"
NEXT_PUBLIC_BACKEND_URL="http://localhost:3000"
BACKEND_INTERNAL_URL="http://localhost:3000"

# =============================================================================
# STORAGE (Local filesystem)
# =============================================================================
STORAGE_PROVIDER="local"
UPLOAD_DIRECTORY="./uploads"

# =============================================================================
# SECURITY (CHANGE THESE!)
# =============================================================================
# Generate a random secret: openssl rand -hex 32
JWT_SECRET="change-this-to-a-random-32-character-string-for-security"

# =============================================================================
# OPTIONAL: Social Media API Keys
# =============================================================================
# Add your API keys here for the platforms you want to post to.
# See https://docs.postiz.com for setup instructions.

# Twitter/X
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=

# LinkedIn
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# Facebook/Instagram
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# TikTok
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# YouTube
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
