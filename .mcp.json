    "tikhub-douyin": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.tikhub.io/douyin/mcp",
        "--header",
        "Authorization: Bearer ${TIKHUB_API_KEY}"
      ]
