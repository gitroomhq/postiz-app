{
  "mcpServers": {
    "tikhub-tiktok": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.tikhub.io/tiktok/mcp",
        "--header",
        "Authorization: Bearer ${TIKHUB_API_KEY}"
      ]
    },
    "tikhub-xiaohongshu": {
