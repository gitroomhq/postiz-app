# .env.local-ui — local UI dev seed
#
# Used by the `frontend-local` / `frontend-local-turbo` launch configs in
# .claude/launch.json (loaded via `dotenv -e ../../.env.local-ui`).
#
# Copy to .env.local-ui at the repo root and fill in real values:
#   cp .env.local-ui.example .env.local-ui
#
# .env.local-ui is gitignored — never commit real keys.

# --- Required: app will not boot without these ---
# Supabase project URL + anon/publishable key (client-side Supabase).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# --- Server-side Supabase (admin/cron/scrape API routes) ---
# Falls back to NEXT_PUBLIC_SUPABASE_URL when unset.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Cron route auth (api/cron/*, api/admin/cron-health) ---
CRON_SECRET=your-cron-secret

# --- Rate limit / cache (api/proxy-image, api/profiles/discover) ---
# Optional locally; routes degrade gracefully when unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Scrapers (api/scrape/*) ---
# TikHub: Instagram / TikTok / RedNote / Douyin. BrightData: Facebook.
TIKHUB_API_KEY=
BRIGHTDATA_API_KEY=

# --- Optional: analytics / monitoring ---
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_SENTRY_DSN=
