{
  "expo": {
    "name": "Postiz Mobile",
    "slug": "postiz-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "postiz",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0e0e0e"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Postiz accesses your photos so you can attach them to scheduled posts.",
          "cameraPermission": "Postiz accesses your camera so you can attach new photos to scheduled posts."
        }
      ]
    ],
    "extra": {
      "backendUrl": "http://localhost:3000",
      "frontendUrl": "http://localhost:4200",
      "mobileAuthCallback": "postiz://auth/callback",
      "mobileIntegrationCallback": "postiz://integrations/done"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
