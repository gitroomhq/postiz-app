{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/daily-snapshot",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/archive-and-purge",
      "schedule": "30 2 * * *"
    }
  ]
}
